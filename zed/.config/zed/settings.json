// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "oh-my-pi": {
      "type": "custom",
      "command": "omp",
      "args": ["acp"],
    },
  },
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "soft_wrap": "editor_width",
  "which_key": {
    "enabled": false,
  },
  "git_panel": {
    "dock": "left",
    "tree_view": false,
  },
  "colorize_brackets": true,
  "window_decorations": "client",
  "tabs": {
    "file_icons": true,
    "git_status": false,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false,
  },
  "language_models": {
    "openai_compatible": {
      "Qwen3Coder": {
        "api_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "available_models": [
          {
            "name": "qwen3-coder-plus",
            "display_name": null,
            "max_tokens": 1000000,
            "max_output_tokens": 65536,
            "max_completion_tokens": 65536,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
          {
            "name": "qwen3-coder-flash",
            "display_name": null,
            "max_tokens": 1000000,
            "max_output_tokens": 65536,
            "max_completion_tokens": 65536,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },

  // basic config
  "auto_update": false,
  "agent": {
    "dock": "right",
    "default_model": {
      "enable_thinking": true,
      "effort": "high",
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
    },
    "default_profile": "ask",
  },
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16.5,
  "buffer_font_size": 15.5,
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 15,
  "buffer_font_family": "Maple Mono NF CN",
  "terminal": {
    "show_count_badge": false,
    "flexible": true,
    "font_size": 15,
    "line_height": "standard",
  },
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Catppuccin Mocha",
  },
  "autosave": "on_focus_change",
  "close_on_file_delete": true,
  "hide_mouse": "on_typing",
  "relative_line_numbers": "enabled",
  "project_panel": {
    "dock": "left",
    "git_status_indicator": true,
  },

  // debugger
  "inlay_hints": { "show_value_hints": false },

  //vim
  "vim_mode": true,
  "helix_mode": true,

  // remote dev
  "ssh_connections": [
    {
      "host": "a6000",
      "args": [],
      "projects": [
        {
          "paths": [
            "/data/yitingting/.config"
          ]
        },
        {
          "paths": [
            "/data/yitingting/github/SimKGC"
          ]
        },
        {
          "paths": [
            "/data/yitingting/github/SynKGR"
          ]
        },
        {
          "paths": [
            "/home/morethan/github/SWE-CI"
          ]
        }
      ]
    },
    {
      "host": "4090x3",
      "args": [],
      "projects": [
        {
          "paths": [
            "/root/github/SynKGR"
          ]
        }
      ]
    },
    {
      "host": "shixi",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/morethan/github/SWE-CI"
          ]
        }
      ]
    }
  ],

  // language server
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
    },
  },
}
