syntax on
filetype plugin indent on

set expandtab
set tabstop=4
set shiftwidth=4
set softtabstop=4

inoremap jj <Esc>
nnoremap ; :
noremap gh ^
noremap gl $
nnoremap <A-j> 10gj
nnoremap <A-k> 10gk
vnoremap <A-j> 10gj
vnoremap <A-k> 10gk

" clip board
" vnoremap <leader>y "+y
" nnoremap <leader>y "+y
